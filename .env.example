# Base URL for the docs app when it runs on a different origin than web.
# Used by apps/web for "Docs" and "Get started" links.
# - Leave unset or set to http://localhost:3000 when running docs on port 3000.
# - Set to "" (empty string) when web and docs are on the same host (e.g. /docs path).
# - Set to full URL (e.g. https://docs.example.com) in production when docs is on a subdomain.
# NEXT_PUBLIC_DOCS_URL=http://localhost:3000

# Secret used to sign the demo session cookie (apps/web). Set a long random string in production.
# SESSION_SECRET=

# Optional B2B API base URL; when set, the dashboard tries GET {NEXT_PUBLIC_API_URL}/health.
# Requests use a default timeout (see @repo/api-client DEFAULT_REQUEST_TIMEOUT_MS); override in code if needed.
# Retries for idempotent GETs are configured on the client (maxRetries, retryDelayMs, retryBackoffFactor).
# Each logical API call sends X-Request-Id (crypto.randomUUID when available); override via getRequestId in code.
# NEXT_PUBLIC_API_URL=http://localhost:4000
